# Copy this file to .env and fill in your real values. Never commit .env

PORT=5000

# Local Postgres (create this DB locally: createdb community_forum)
DB_NAME=community_forum
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_HOST=127.0.0.1
DB_PORT=5432

# When you deploy to Render, it gives you a single connection string instead.
# If DATABASE_URL is set, server.js will use that instead of the fields above.
# DATABASE_URL=postgres://user:pass@host:port/dbname

JWT_SECRET=replace_this_with_a_long_random_string
JWT_EXPIRES_IN=7d
